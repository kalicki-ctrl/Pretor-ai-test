# ===================================================
# PRETOR AI — Variáveis de Ambiente
# ===================================================
# Copie este arquivo para .env e preencha com suas chaves:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
#
# Obtenha suas chaves nos links abaixo:
#   OpenRouter: https://openrouter.ai/keys
#   Groq:       https://console.groq.com/keys
#   Cohere:     https://dashboard.cohere.com/api-keys
#   Gemini:     https://aistudio.google.com/app/apikey
# ===================================================

# API Keys das IAs (pelo menos uma é necessária)
OPENROUTER_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
GEMINI_API_KEY=

# Cache Redis (opcional — funciona sem)
REDIS_URL=

# CORS — origens permitidas separadas por vírgula (opcional — usa localhost:5000 por padrão)
# Exemplo em produção: CORS_ORIGIN=https://meusite.com
CORS_ORIGIN=
