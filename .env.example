# ===================================================
# PRETOR AI — Variáveis de Ambiente
# ===================================================
# Copie este arquivo para .env e preencha com suas chaves:
#   cp .env.example .env
#
# Obtenha suas chaves nos links abaixo:
#   OpenRouter: https://openrouter.ai/keys
#   Groq:       https://console.groq.com/keys
#   Cohere:     https://dashboard.cohere.com/api-keys
#   Google:     https://aistudio.google.com/app/apikey
# ===================================================

# Banco de dados (opcional — usa memória por padrão)
DATABASE_URL=

# API Keys das IAs
OPENROUTER_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Cache Redis (opcional — funciona sem)
REDIS_URL=
